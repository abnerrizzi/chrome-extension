<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="core-001-scrape-sessions" author="claude">
        <preConditions onFail="HALT">
            <not><tableExists tableName="scrape_sessions"/></not>
        </preConditions>

        <createTable tableName="scrape_sessions">
            <column name="id" type="${autoIncrement.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="domain_name" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="item_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="${timestamp.type}" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="ix_scrape_sessions_domain"
                     tableName="scrape_sessions">
            <column name="domain_name"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="ix_scrape_sessions_domain" tableName="scrape_sessions"/>
            <dropTable tableName="scrape_sessions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
