<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="linkedin-001-jobs" author="claude">
        <preConditions onFail="HALT">
            <tableExists tableName="scrape_sessions"/>
            <not><tableExists tableName="linkedin_jobs"/></not>
        </preConditions>

        <createTable tableName="linkedin_jobs">
            <column name="id" type="${autoIncrement.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="session_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_linkedin_jobs_session"
                             references="scrape_sessions(id)"/>
            </column>
            <column name="job_title"   type="VARCHAR(256)"><constraints nullable="false"/></column>
            <column name="company"     type="VARCHAR(256)"/>
            <column name="location"    type="VARCHAR(256)"/>
            <column name="seniority"   type="VARCHAR(64)"/>
            <column name="skills"      type="${json.type}"/>
            <column name="posted_at"   type="${timestamp.type}"/>
            <column name="created_at"  type="${timestamp.type}" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="linkedin_jobs"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
