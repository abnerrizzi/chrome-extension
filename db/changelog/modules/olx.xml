<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="olx-001-listings" author="claude">
        <preConditions onFail="HALT">
            <tableExists tableName="scrape_sessions"/>
            <not><tableExists tableName="olx_listings"/></not>
        </preConditions>

        <createTable tableName="olx_listings">
            <column name="id" type="${autoIncrement.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="session_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_olx_listings_session"
                             references="scrape_sessions(id)"/>
            </column>
            <column name="title"        type="VARCHAR(512)"><constraints nullable="false"/></column>
            <column name="price_cents"  type="BIGINT"/>
            <column name="currency"     type="CHAR(3)" defaultValue="BRL"/>
            <column name="category"     type="VARCHAR(128)"/>
            <column name="city"         type="VARCHAR(128)"/>
            <column name="state"        type="VARCHAR(64)"/>
            <column name="latitude"     type="NUMERIC(9,6)"/>
            <column name="longitude"    type="NUMERIC(9,6)"/>
            <column name="images"       type="${json.type}"/>
            <column name="url"          type="VARCHAR(1024)"><constraints nullable="false"/></column>
            <column name="posted_at"    type="${timestamp.type}"/>
            <column name="created_at"   type="${timestamp.type}" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="ix_olx_listings_category" tableName="olx_listings">
            <column name="category"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="ix_olx_listings_category" tableName="olx_listings"/>
            <dropTable tableName="olx_listings"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
