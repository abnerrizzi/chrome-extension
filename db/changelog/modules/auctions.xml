<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="auctions-001-items" author="claude">
        <preConditions onFail="HALT">
            <tableExists tableName="scrape_sessions"/>
            <not><tableExists tableName="auction_items"/></not>
        </preConditions>

        <createTable tableName="auction_items">
            <column name="id" type="${autoIncrement.type}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="session_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_auction_items_session"
                             references="scrape_sessions(id)"/>
            </column>
            <column name="lot_code"          type="VARCHAR(64)"><constraints nullable="false"/></column>
            <column name="title"             type="VARCHAR(512)"><constraints nullable="false"/></column>
            <column name="current_bid_cents" type="BIGINT"><constraints nullable="false"/></column>
            <column name="min_increment_cents" type="BIGINT"/>
            <column name="currency"          type="CHAR(3)" defaultValue="BRL"/>
            <column name="auction_end"       type="${timestamp.type}"><constraints nullable="false"/></column>
            <column name="url"               type="VARCHAR(1024)"><constraints nullable="false"/></column>
            <column name="created_at"        type="${timestamp.type}" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="ix_auction_items_end" tableName="auction_items">
            <column name="auction_end"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="ix_auction_items_end" tableName="auction_items"/>
            <dropTable tableName="auction_items"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
