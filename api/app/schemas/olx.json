{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OlxHouseItem",
  "type": "object",
  "required": ["title", "url"],
  "properties": {
    "external_id":          { "type": "string", "description": "ID numérico extraído da URL OLX" },
    "title":                { "type": "string", "description": "Título do anúncio" },
    "url":                  { "type": "string", "description": "URL canônica do anúncio" },
    "price_raw":            { "type": "string", "description": "Preço como string (R$ 2.250.000)" },
    "listing_kind":         { "type": "string", "description": "categoryName do OLX (ex: 'Casas')" },
    "kind":                 { "type": "string", "enum": ["venda", "aluguel"], "description": "Módulo do imóvel" },
    "real_estate_type_raw": { "type": "string", "description": "valor cru de properties.real_estate_type (ex: 'Venda - casa em rua pública')" },
    "category_raw":         { "type": "string", "description": "valor cru de properties.category (ex: 'Casas')" },
    "location":             { "type": "string", "description": "string composta bairro, cidade, UF (uso preview)" },
    "neighbourhood":        { "type": "string", "description": "locationDetails.neighbourhood" },
    "city_raw":             { "type": "string", "description": "locationDetails.municipality" },
    "state_raw":            { "type": "string", "description": "locationDetails.uf" },
    "date_raw":             { "type": "string", "description": "Data localizada (ex: '9 de mai, 04:58') ou unix epoch como string" },
    "image_url":            { "type": "string", "description": "URL da thumbnail principal" },
    "iptu_raw":             { "type": "string", "description": "Texto IPTU bruto (ex: 'IPTU R$ 1.000')" },
    "bedrooms_raw":         { "type": "string", "description": "aria-label de quartos (ex: '3 quartos')" },
    "bathrooms_raw":        { "type": "string", "description": "aria-label de banheiros" },
    "garage_spaces_raw":    { "type": "string", "description": "aria-label de vagas/garagem" },
    "area_raw":             { "type": "string", "description": "aria-label de área (ex: '230 metros quadrados')" }
  }
}
